    "license": "LGPL",
    "flag": "INCOMPLETE"
  },
  {
    "chunk_id": "1c424afe-be52-4294-a894-f35402502037",
    "source_type": "track_a",
    "software": "DWSIM",
    "topic": "Flowsheet Object Interfaces and Automation",
    "steps": [],
    "params": {},
    "ui_paths": [],
    "errors": [],
    "fixes": [],
    "theory": "DWSIM's Flowsheet object implements multiple interfaces: IFlowsheet (main access), IFlowsheetBag (object collections), IFlowsheetGUI (GUI helpers), and IFlowsheetOptions (settings). The Automation class returns an IFlowsheet object when loading simulations.",
    "source_url": "https://dwsim.org/wiki/index.php?title=Automation",
    "license": "LGPL",
    "flag": "INCOMPLETE"
  },
  {
