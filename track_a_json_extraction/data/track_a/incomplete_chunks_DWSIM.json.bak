  {
    "chunk_id": "bf222da0-cf21-4c65-bf52-19a05a77ddda",
    "source_type": "track_a",
    "software": "DWSIM",
    "topic": "Automation Overview",
    "steps": [],
    "params": {},
    "ui_paths": [],
    "errors": [],
    "fixes": [],
    "theory": "Automation enables software packages to expose their unique features to scripting tools and other applications. On Windows, exposed objects are ActiveX objects, defined and exposed by applications and accessed by ActiveX clients. ActiveX components (.exe and .dll files) contain classes which are definitions of objects, and type information describes these objects for use at compile or run time.",
    "source_url": "https://dwsim.org/wiki/index.php?title=Automation",
    "license": "LGPL",
    "flag": "INCOMPLETE"
  },
  {
    "chunk_id": "12c88fc2-303c-46c0-8602-7b15eb3471bf",
    "source_type": "track_a",
    "software": "DWSIM",
    "topic": "Registering DLLs for COM Automation",
    "steps": [
      "Register DWSIM DLLs for automation during the installation process",
      "Run automation_reg.bat with admin privileges to register DLLs",
      "Run automation_unreg.bat with admin privileges to de-register DLLs",
      "Add a reference to the DLLs for .NET-based automation projects"
    ],
    "params": {},
    "ui_paths": [],
    "errors": [],
    "fixes": [],
    "theory": "Starting from version 4.2, DWSIM exposes its main Classes and Interfaces to Automation via COM/.NET, allowing for flowsheet manipulation and sensitivity/optimization studies via external tools like Excel VBA.",
    "source_url": "https://dwsim.org/wiki/index.php?title=Automation",
    "license": "LGPL",
    "flag": "INCOMPLETE"
  },
  {
    "chunk_id": "5cc761cf-5394-4887-863a-5d7eed8e9ca1",
    "source_type": "track_a",
    "software": "DWSIM",
    "topic": "Automation and API Structure",
    "steps": [],
    "params": {},
    "ui_paths": [],
    "errors": [],
    "fixes": [],
    "theory": "DWSIM supports automation via .NET languages and COM interfaces. The Flowsheet class serves as the primary entry point for accessing the Thermodynamics Subsystem, Simulation Objects Subsystem, and Graphical User Interface components.",
