    "software": "DWSIM",
    "topic": "Thermodynamic Model Selection",
    "steps": [],
    "params": {},
    "ui_paths": [],
    "errors": [],
    "fixes": [],
    "theory": "Provides criteria for selecting property packages based on fluid properties: use Raoult's Law for low-pressure non-polar gases; EOS models (PR, SRK, PRSV2) for high-pressure systems; Chao-Seader, Grayson-Streed, or LKP for hydrogen-rich systems; CoolProp/FPROPS for refrigeration; Steam Tables for water; NRTL, UNIQUAC, or UNIFAC for polar chemicals; and Seawater or Electrolyte packages for salt systems.",
    "source_url": "https://dwsim.org/wiki/index.php?title=Property_Package_Selection",
    "license": "LGPL",
    "flag": "INCOMPLETE"
  },
