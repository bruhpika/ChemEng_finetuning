    "source_type": "track_a",
    "software": "DWSIM",
    "topic": "DWSIM Automation with C# and VB.NET",
    "steps": [
      "Create a new C# Console Application project",
      "Add references to DWSIM.Automation.dll, DWSIM.Interfaces.dll, and CapeOpen.dll",
