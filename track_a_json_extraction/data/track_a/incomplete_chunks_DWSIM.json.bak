  },
  {
    "chunk_id": "d279adcc-9ea7-4782-9816-75a9530a8359",
    "source_type": "track_a",
    "software": "DWSIM",
    "topic": "Data Entry and Estimation in Data Regression Utility",
    "steps": [
      "Enter experimental data into the table, inputting the temperature or pressure only on the first cell of the corresponding column for Txy or Pxy data.",
      "Select cells and press the 'Del' key to clear data.",
      "Select all cells on a row and press 'Shift+Del' to remove the entire row.",
      "Select cells with missing data, right-click, and select a thermodynamic model to estimate missing vapor phase mole fractions, temperatures, or pressures.",
      "In the 'Regression Parameters' section, select an optimization method from the 'Method' combobox.",
      "Select an Objective Function from the corresponding combobox."
    ],
    "params": {
      "Method": "Selection of the optimization method for regression.",
      "Objective Function": "Selection of the objective function (e.g., Least Squares min T/P or min y)."
    },
    "ui_paths": [],
    "errors": [],
    "fixes": [],
    "theory": "The utility uses models with known interaction parameters to estimate missing data. The Least Squares (min T/P) objective function minimizes the difference between calculated and experimental pressures/temperatures, while Least Squares (min y) minimizes the difference for vapor phase mole fractions.",
    "source_url": "https://dwsim.org/wiki/index.php?title=Using_the_Data_Regression_Utility",
    "license": "LGPL",
    "flag": "INCOMPLETE"
  },
