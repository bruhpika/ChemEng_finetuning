  {
    "chunk_id": "fede40f2-2810-41cb-90fa-6ef70dbf0245",
    "source_type": "track_a",
    "software": "DWSIM",
    "topic": "Overriding Property Package Fugacity Coefficient Calculation Routines",
    "steps": [
      "Set OverrideCalculationRoutine to True for the target object.",
      "Assign a custom calculation function to the CalculationRoutineOverride property.",
      "Access the Property Package via Flowsheet.PropertyPackagesArray.",
      "Define a function to calculate the roots of a cubic polynomial for the Property Package.",
      "Utilize DWSIM's internal CalcRoots function within the script for auxiliary calculations."
    ],
    "params": {
      "OverrideCalculationRoutine": "Property to enable or disable the custom script override",
      "CalculationRoutineOverride": "Property to assign the custom script function",
      "Flowsheet.PropertyPackagesArray": "Collection used to access simulation property packages"
    },
    "ui_paths": [],
    "errors": [],
    "fixes": [],
    "theory": "Fugacity coefficients are calculated by K-value routines, which are utilized by flash algorithms for equilibrium calculations. For cubic equations of state like Peng-Robinson, this involves solving a cubic polynomial to find real roots.",
    "source_url": "https://dwsim.org/wiki/index.php?title=Model_Customization",
    "license": "LGPL",
    "flag": "INCOMPLETE"
  },
  {
    "chunk_id": "8a7dcfdf-7aea-4861-9efe-780bec6cd17a",
