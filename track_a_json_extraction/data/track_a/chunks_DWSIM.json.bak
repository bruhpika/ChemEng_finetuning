    "steps": [],
    "params": {},
    "ui_paths": [],
    "errors": [],
    "fixes": [],
    "theory": "The Spoken Tutorial Project teaches Free/Libre and Open Source Software (FLOSS) like DWSIM via easy video screencasts with running commentary, designed for self-learning. Each tutorial is approximately ten minutes long and can facilitate 'Spoken Tutorial based Education and Learning through Free FLOSS study' (SELF) workshops. This project is an initiative of the 'Talk to a Teacher' project under the National Mission on Education through Information and Communication Technology, launched by MHRD, Govt of India.",
    "source_url": "https://dwsim.fossee.in/spoken-tutorial",
    "license": "LGPL",
    "flag": "INCOMPLETE"
  },
