  {
    "chunk_id": "17644476-3e7c-4a01-ae32-dbbe53835833",
    "source_type": "track_a",
    "software": "DWSIM",
    "topic": "PT Flash Calculation",
    "steps": [
      "Set the thermodynamic property package to NRTL.",
      "Set the stream's overall pressure, temperature, and mass flow.",
      "Specify the flash calculation type as Pressure-Temperature (PT).",
      "Perform the flash calculation.",
      "Retrieve and display mass flow and density for the vapor phase.",
      "Retrieve and display mass flow and density for the liquid phase.",
      "Retrieve and display overall molar flow for each compound.",
      "Retrieve and display molar flow for each compound in the vapor phase.",
      "Retrieve and display molar flow for each compound in the liquid phase."
    ],
    "params": {
      "temperature": "<user_defined_value>",
      "temperature_unit": "K",
      "pressure": "<user_defined_value>",
      "pressure_unit": "Pa",
      "mass_flow": 1000.0,
      "mass_flow_unit": "kg/s",
      "water_molar_fraction": 0.5,
      "ethanol_molar_fraction": 0.5,
      "property_package": "NRTL",
      "flash_type": "PT"
    },
    "ui_paths": [
      "Simulation > Property Packages > Add/Edit Property Package > Select NRTL",
      "Flowsheet > [Select Material Stream] > Input (Tab) > Set Temperature",
      "Flowsheet > [Select Material Stream] > Input (Tab) > Set Pressure",
      "Flowsheet > [Select Material Stream] > Input (Tab) > Set Mass Flow",
      "Flowsheet > [Select Material Stream] > Compounds (Tab) > Set Molar Fractions for Water and Ethanol"
    ],
    "errors": [],
    "fixes": [],
    "theory": "Phase equilibrium, specifically vapor-liquid equilibrium (VLE), governed by thermodynamic property packages like NRTL. The calculation determines the distribution of components between vapor and liquid phases at specified temperature and pressure (PT Flash).",
    "source_url": "https://gist.github.com/DanWBR/4a803cf325ae89a2663d9cdd0e8a61a2",
    "license": "LGPLv3 / GPLv3"
  },
