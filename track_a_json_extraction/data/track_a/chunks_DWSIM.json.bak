  {
    "chunk_id": "db8c626c-10a1-4509-b6bb-9c15443dbeae",
    "source_type": "track_a",
    "software": "DWSIM",
    "topic": "Overview and Core Features",
    "steps": [],
    "params": {
      "Thermodynamic Models": {
        "Equations of State": [
          "Peng-Robinson",
          "PRSV2",
          "Soave-Redlich-Kwong",
          "Lee-Kesler-Pl\u00f6cker"
        ],
        "Activity Coefficient Models": [
          "NRTL",
          "UNIQUAC",
          "Wilson",
          "UNIFAC"
        ],
        "Specialty Packages": [
          "Steam tables",
          "CoolProp integration"
        ]
      },
      "Petroleum Characterization": [
        "Riazi correlations",
        "pseudo-component generation"
      ]
    },
    "ui_paths": [],
    "errors": [],
    "fixes": [],
    "theory": "DWSIM applies rigorous thermodynamics, incorporating decades of chemical engineering theory. It uses industry-standard, peer-reviewed models including Equations of State (e.g., Peng-Robinson, PRSV2, Soave-Redlich-Kwong, Lee-Kesler-Pl\u00f6cker), Activity Coefficient Models (e.g., NRTL, UNIQUAC, Wilson, UNIFAC), and specialty packages like Steam tables and CoolProp integration for pure fluids and incompressible mixtures. It also includes methods for petroleum characterization such as Riazi correlations and pseudo-component generation.",
    "source_url": "https://dwsim.org/",
    "license": "GPLv3",
    "flag": "INCOMPLETE"
  },
  {
    "chunk_id": "c3dd5708-dc4d-4863-94ea-322dbd279321",
    "source_type": "track_a",
    "software": "DWSIM",
    "topic": "Software Capabilities and Features Overview",
    "steps": [],
    "params": {},
    "ui_paths": [],
    "errors": [],
    "fixes": [],
    "theory": "Wilson equation, UNIFAC, Steam tables, CoolProp integration, Riazi correlations, pseudo-component generation, true critical point calculation, rigorous distillation, shortcut distillation, CSTR, PFR, equilibrium reactors, detailed hydraulic calculations, detailed heat-transfer calculations, steady-state simulation, dynamic simulation, rigorous time-stepping integrators, event scheduling, NIST ThermoML Archive, phase-equilibrium datasets, pure-compound property records, Joback method, Lee-Kesler method, Ambrose method, Riedel method, Rackett method, classic estimation methods, binary phase equilibrium",
    "source_url": "https://dwsim.org/",
    "license": "GPLv3",
    "flag": "INCOMPLETE"
  },
  {
    "chunk_id": "ad77cd03-1e19-41fa-a34f-47c76253eb5a",
    "source_type": "track_a",
    "software": "DWSIM",
    "topic": "Phase Equilibrium Data Regression and Electrolyte Modeling",
    "steps": [
      "Open the Data Regression tool.",
      "Search the local ThermoML index for VLE / LLE / SLE / VLLE datasets matching your compound pair.",
      "Filter the results by equilibrium type and T/P range.",
      "Preview the citation for the selected dataset.",
      "Load experimental x\u2013y\u2013T\u2013P points into the regression grid.",
      "Fit interaction parameters using models such as PR, SRK, PRSV2, NRTL, UNIQUAC, PC-SAFT, or Lee-Kesler-Pl\u00f6cker."
    ],
    "params": {
      "equilibrium_types": [
        "VLE",
        "LLE",
        "SLE",
        "VLLE"
      ],
      "interaction_parameters_models": [
        "PR",
        "SRK",
        "PRSV2",
        "NRTL",
        "UNIQUAC",
        "PC-SAFT",
        "Lee-Kesler-Pl\u00f6cker"
      ],
      "electrolyte_models": [
        "Electrolyte NRTL (Chen & Evans)",
        "Extended UNIQUAC (Thomsen)"
      ],
      "electrolyte_phenomena_solved": [
        "dissociation",
        "salt precipitation",
        "complexation",
        "vapor-liquid equilibrium"
      ]
    },
    "ui_paths": [
      "Data Regression tool",
      "Compound Creator",
      "Simulation Wizard",
      "Simulation Settings",
      "Data Regression forms"
    ],
    "errors": [],
    "fixes": [],
    "theory": "Every property imported into DWSIM carries its provenance: a source citation or estimator name. DWSIM's Electrolytes extension (Patreon Edition exclusive) uses a unified equilibrium engine driven by industry-standard activity-coefficient models, Electrolyte NRTL (Chen & Evans) and Extended UNIQUAC (Thomsen), to solve dissociation, salt precipitation, complexation, and vapor-liquid equilibrium in a single pass, ensuring atom and charge balance across liquid, solid, and vapor phases.",
    "source_url": "https://dwsim.org/",
    "license": "GPLv3"
  },
  {
    "chunk_id": "27e4893f-e8bf-4e5f-a718-523c86132f58",
    "source_type": "track_a",
    "software": "DWSIM",
    "topic": "Advanced Thermodynamics, Speciation, and AI Features",
    "steps": [],
    "params": {},
    "ui_paths": [],
    "errors": [
      "convergence issues",
      "calculation non-convergence",
      "flowsheet issues"
    ],
    "fixes": [
      "flowsheet generation",
      "accelerated workflow",
      "context-aware answers",
      "script generation (Python and VB.NET) for automation"
    ],
    "theory": "DWSIM supports advanced thermodynamic calculations including complexation and vapor-liquid equilibrium, atom and charge balance, and speciation. It utilizes Electrolyte NRTL and Extended UNIQUAC property packages and handles multi-salt precipitation with simultaneous Ksp solving. Key parameters like pH, ionic strength, activity coefficients, and saturation indices are calculated per stream. It also provides a Phase Diagram Utility for T\u2013w, ternary, solubility-vs-temperature, and activity-coefficient plots.",
    "source_url": "https://dwsim.org/",
    "license": "GPLv3",
    "flag": "INCOMPLETE"
  },
  {
