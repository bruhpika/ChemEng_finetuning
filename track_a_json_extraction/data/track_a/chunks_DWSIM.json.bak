  },
  {
    "chunk_id": "06bfcb74-07f2-4439-8852-9538b43b903f",
    "source_type": "track_a",
    "software": "DWSIM",
    "topic": "Thermodynamic Residual Property Calculation (Peng-Robinson EOS)",
    "steps": [
      "Calculate dimensionless parameters AG and BG for the cubic equation of state.",
      "Define coefficients for the cubic equation and solve for real roots to determine the compressibility factor.",
      "Select the appropriate compressibility factor (Z) root based on whether the state is liquid (minimum root) or vapor (maximum root).",
      "Calculate the temperature derivative of the mixture attraction parameter (amix) using mixing rules and interaction parameters.",
      "Compute residual Helmholtz energy (DAres), residual entropy (DSres), and residual enthalpy (DHres) using the compressibility factor and EOS parameters.",
      "Calculate the final mixture specific enthalpy by adding residual enthalpy to ideal enthalpy and dividing by mixture molar weight."
    ],
    "params": {
      "amix": "Mixture attraction parameter",
      "bmix": "Mixture co-volume parameter",
      "P": "Pressure",
      "T": "Temperature",
      "R": "Gas constant",
      "state": "Physical state of the fluid (Liquid or Vapor)",
      "kij": "Binary interaction parameters",
      "Vz": "Molar fractions of components",
      "Tc": "Critical temperature",
      "Pc": "Critical pressure",
      "Hid": "Ideal gas enthalpy",
      "MW": "Mixture molar weight"
    },
    "ui_paths": [
      "Scripting Console",
      "Model Customization > Custom Property Package"
    ],
    "errors": [],
    "fixes": [],
    "theory": "This script implements the Peng-Robinson Equation of State (EOS) logic. It calculates the compressibility factor (Z) by solving the cubic EOS equation and subsequently derives residual thermodynamic properties (Helmholtz energy, entropy, and enthalpy) to determine the real fluid enthalpy.",
    "source_url": "https://dwsim.org/wiki/index.php?title=Model_Customization",
    "license": "LGPL"
  },
  {
    "chunk_id": "3272caf1-c603-47c3-ae21-2e19c359a5da",
    "source_type": "track_a",
    "software": "DWSIM",
    "topic": "Overriding Calculated Properties",
    "steps": [
      "Navigate to the Basis settings in the simulation environment.",
      "Locate the Added Property Packages section.",
      "Select an added Property Package from the list.",
      "Click on the Advanced button.",
      "Go to the Property Overrides section.",
      "Write or paste the Python override script.",
      "Click Save to store the override script on the Property Package.",
      "Solve the simulation to apply the override and check the calculated value."
    ],
    "params": {},
    "ui_paths": [
      "Edit > Simulation Settings > Basis > Added Property Packages > Advanced > Property Overrides",
      "Setup > Basis > Added Property Packages > Advanced > Property Overrides"
    ],
    "errors": [],
    "fixes": [],
    "theory": "Starting from DWSIM Version 5.1, phase properties can be overridden through Python scripts. This is useful when calculated property values deviate significantly from expected values or when advanced mixing rules are required for mixed phase property calculations.",
    "source_url": "https://dwsim.org/wiki/index.php?title=Overriding_Calculated_Properties",
    "license": "LGPL"
  },
  {
    "chunk_id": "6959cfa9-f62c-47f9-9875-dfa9d8278701",
    "source_type": "track_a",
    "software": "DWSIM",
    "topic": "Water/Hydrocarbon Emulsion Viscosity Property Override",
    "steps": [
      "Click 'Save' to store the override script on the Property Package.",
      "Solve the simulation and check the calculated value.",
      "Open the Property Override editor.",
      "Enter the provided Python script for the 'OverallLiquid/viscosity' property."
    ],
    "params": {
      "property": "OverallLiquid/viscosity"
    },
    "ui_paths": [
      "Property Package",
      "Property Override editor"
    ],
    "errors": [],
    "fixes": [],
    "theory": "The simulation replaces the mass fraction weighted average for liquid mixture viscosity with an emulsion equation: mu = (mu_w / delta_w)[1+1.5*mu_h*delta_h(mu_w+mu_h)], where mu is viscosity and delta is volumetric fraction for water (w) and hydrocarbon (h) phases.",
    "source_url": "https://dwsim.org/wiki/index.php?title=Overriding_Calculated_Properties",
    "license": "LGPL"
  },
  {
    "chunk_id": "50d33c6c-17eb-4db3-b91f-646f2f4c4977",
    "source_type": "track_a",
    "software": "DWSIM",
    "topic": "Overriding Liquid Mixture Viscosity",
    "steps": [
      "Retrieve viscosity and volumetric flow properties for hydrocarbon (Liquid1) and water (Liquid2) phases",
      "Calculate volumetric fractions for both phases based on individual volumetric flows",
      "Apply the emulsion equation to calculate the updated liquid mixture viscosity",
      "Run the simulation to view the effect of the updated viscosity on the pipe pressure profile"
    ],
    "params": {
      "mu_h": "Liquid hydrocarbon phase viscosity",
      "mu_w": "Liquid water phase viscosity",
      "vflow_h": "Liquid hydrocarbon phase volumetric flow",
      "vflow_w": "Liquid water phase volumetric flow",
      "vf_h": "Liquid hydrocarbon phase volumetric fraction",
      "vf_w": "Liquid water phase volumetric fraction",
      "propval": "Updated liquid mixture (emulsion) viscosity"
    },
    "ui_paths": [],
    "errors": [],
    "fixes": [],
    "theory": "The liquid mixture (emulsion) viscosity is calculated using phase properties according to the formula: propval = (mu_w/vf_w) * (1.0 + 1.5 * mu_h * vf_h / (mu_w + mu_h)).",
    "source_url": "https://dwsim.org/wiki/index.php?title=Overriding_Calculated_Properties",
    "license": "LGPL",
    "flag": "INCOMPLETE"
  },
