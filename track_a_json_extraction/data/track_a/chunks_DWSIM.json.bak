    "steps": [
      "Extract polynomial coefficients a, b, c, and d from the input array.",
      "Call the internal DWSIM PolySolve.CalcRoots function to calculate roots of the cubic equation.",
      "Initialize a 2D array to store the real and imaginary components of the roots.",
      "Perform a manual sort of the roots in ascending order based on their real parts.",
      "Filter the results to extract only valid real roots where the imaginary part is zero and the real part is positive.",
      "Return the list of valid real roots for further thermodynamic calculations.",
      "Define the fugcoeff function to calculate fugacity coefficients based on volume, temperature, and pressure."
    ],
    "params": {
      "coeffs": "Array containing polynomial coefficients",
      "res": "Result matrix from PolySolve.CalcRoots",
      "roots": "Array containing sorted real and imaginary parts of roots",
      "validroots": "List of valid positive real roots",
      "Vz": "Compressibility factor or volume",
      "T": "Temperature",
      "P": "Pressure",
      "state": "Phase state identifier"
    },
    "ui_paths": [],
