    "topic": "Unit Operation / Material Stream Calculation Routine Override",
    "steps": [
      "Define a Python function that takes no arguments to perform calculations and set properties of outlet material streams.",
      "Set the OverrideCalculationRoutine property of the unit operation or material stream to true.",
      "Set the CalculationRoutineOverride property to the name of the defined Python function.",
      "Update the code by clicking the 'Run Script' button in the Script Manager.",
      "Associate the script with the 'Simulation Opened' event to ensure it executes automatically when the file is loaded."
    ],
    "params": {
      "OverrideCalculationRoutine": "true",
      "CalculationRoutineOverride": "function name"
    },
