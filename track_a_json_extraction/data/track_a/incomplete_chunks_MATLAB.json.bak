        "ArrayToStruct": "Force use of JData ND array annotations",
        "UseArrayShape": "Use _ArrayShape_ annotation for special matrices"
      },
      "loadjson": {
        "SimplifyCell": "Flag to control cell array simplification"
      }
    },
