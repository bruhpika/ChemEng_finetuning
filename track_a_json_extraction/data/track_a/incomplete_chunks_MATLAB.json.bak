    "software": "MATLAB",
    "topic": "JData encoding and decoding",
    "steps": [
      "Use jdataencode to transform complex MATLAB data structures into JSON-serializable forms.",
      "Use savejson to export the encoded structure to a JSON file.",
      "Use jdatadecode to convert JData-annotated JSON structures back to native MATLAB data structures."
    ],
    "params": {
      "jdataencode": [
        "'annotatearray'",
        "'prefix'",
        "'usearrayshape'"
      ]
    },
    "ui_paths": [],
